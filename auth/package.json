{
    "name": "@microsoft/vscode-azext-azureauth",
    "author": "Microsoft Corporation",
    "version": "6.1.0-alpha.2",
    "description": "Azure authentication helpers for Visual Studio Code",
    "tags": [
        "azure",
        "vscode"
    ],
    "keywords": [
        "azure",
        "vscode"
    ],
    "exports": {
        ".": {
            "import": "./dist/esm/src/index.js",
            "require": "./dist/cjs/src/index.js",
            "types": "./dist/esm/src/index.d.ts"
        },
        "./azdo": {
            "import": "./dist/esm/src/providers/AzureDevOpsSubscriptionProvider.js",
            "require": "./dist/cjs/src/providers/AzureDevOpsSubscriptionProvider.js",
            "types": "./dist/esm/src/providers/AzureDevOpsSubscriptionProvider.d.ts"
        }
    },
    "module": "dist/esm/src/index.js",
    "main": "dist/cjs/src/index.js",
    "types": "dist/esm/src/index.d.ts",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Microsoft/vscode-azuretools"
    },
    "bugs": {
        "url": "https://github.com/Microsoft/vscode-azuretools/issues"
    },
    "homepage": "https://github.com/Microsoft/vscode-azuretools/blob/main/auth/README.md",
    "scripts": {
        "build": "pnpm run build:esm && pnpm run build:cjs",
        "build:esm": "tsc -p ./",
        "build:cjs": "tsc -p ./ --outDir ./dist/cjs --module nodenext --moduleResolution nodenext --declaration false",
        "lint": "eslint --max-warnings 0",
        "test": "mocha",
        "package": "pnpm pack",
        "l10n": "pnpx @vscode/l10n-dev export --outDir ./l10n ./src"
    },
    "engines": {
        "vscode": "^1.106.0"
    },
    "devDependencies": {
        "@microsoft/vscode-azext-eng": "^1.1.0-alpha.1",
        "@types/node": "catalog:",
        "@types/vscode": "1.106.0"
    },
    "dependencies": {
        "@azure/arm-resources-subscriptions": "catalog:",
        "@azure/core-auth": "catalog:",
        "@azure/core-rest-pipeline": "catalog:",
        "@azure/identity": "^4.13.1",
        "@azure/ms-rest-azure-env": "catalog:"
    },
    "publishConfig": {
        "tag": "alpha"
    },
    "mocha": {
        "ui": "tdd",
        "node-option": [
            "experimental-transform-types",
            "disable-warning=ExperimentalWarning",
            "import=@microsoft/vscode-azext-eng/mocha"
        ],
        "spec": [
            "test/**/*.test.ts"
        ]
    }
}
