{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Tests",
            "request": "launch",
            "runtimeArgs": [
                "test",
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "Run Perf Profiler",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--profile=Default",
                "--extensionDevelopmentPath=${workspaceFolder}/test/perf/test-extension"
            ],
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ],
            "preLaunchTask": "npm: build"
        }
    ]
}
