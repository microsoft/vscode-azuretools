{
    "name": "@microsoft/vscode-azext-azureutils",
    "author": "Microsoft Corporation",
    "version": "4.3.0",
    "description": "Common Azure utils for developing Azure extensions for VS Code",
    "tags": [
        "azure",
        "vscode"
    ],
    "keywords": [
        "azure",
        "vscode"
    ],
    "module": "dist/esm/src/index.js",
    "main": "dist/cjs/src/index.js",
    "types": "index.d.ts",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Microsoft/vscode-azuretools"
    },
    "bugs": {
        "url": "https://github.com/Microsoft/vscode-azuretools/issues"
    },
    "homepage": "https://github.com/Microsoft/vscode-azuretools/blob/main/azure/README.md",
    "scripts": {
        "build": "pnpm run build:esm && pnpm run build:cjs",
        "build:esm": "tsc -p ./",
        "build:cjs": "tsc -p ./ --outDir ./dist/cjs --module nodenext --moduleResolution nodenext --declaration false",
        "lint": "eslint --max-warnings 0",
        "test": "vscode-test",
        "package": "pnpm pack",
        "l10n": "pnpx @vscode/l10n-dev export --outDir ./l10n ./src"
    },
    "engines": {
        "vscode": "^1.105.0"
    },
    "dependencies": {
        "@azure/arm-authorization": "^9.0.0",
        "@azure/arm-authorization-profile-2020-09-01-hybrid": "^2.1.0",
        "@azure/arm-msi": "^2.2.0",
        "@azure/arm-resources": "^5.0.0",
        "@azure/arm-resources-profile-2020-09-01-hybrid": "^2.1.0",
        "@azure/arm-resources-subscriptions": "catalog:",
        "@azure/arm-storage": "^18.6.0",
        "@azure/arm-storage-profile-2020-09-01-hybrid": "^2.1.0",
        "@azure/core-client": "catalog:",
        "@azure/core-rest-pipeline": "catalog:",
        "@azure/logger": "^1.3.0",
        "@microsoft/vscode-azext-azureauth": "^6.1.0-alpha.2",
        "@microsoft/vscode-azext-utils": "^4.1.1",
        "@microsoft/vscode-azureresources-api": "catalog:",
        "semver": "catalog:"
    },
    "peerDependencies": {
        "@azure/ms-rest-azure-env": "catalog:"
    },
    "devDependencies": {
        "@azure/core-auth": "catalog:",
        "@azure/core-paging": "^1.6.2",
        "@microsoft/vscode-azext-eng": "^1.1.0-alpha.1",
        "@types/node": "catalog:",
        "@types/semver": "catalog:",
        "@types/vscode": "catalog:",
        "@vscode/test-cli": "catalog:",
        "@vscode/test-electron": "catalog:",
        "tsx": "catalog:"
    }
}
